<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SAV → Excel 변환기</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #F4F5F7;
      --surface: #FFFFFF;
      --border: #E4E6EA;
      --border-hover: #C8CBCF;
      --text-primary: #1A1D23;
      --text-secondary: #6B7280;
      --text-tertiary: #9CA3AF;
      --accent: #1D9E75;
      --accent-light: #E1F5EE;
      --accent-dark: #177A5C;
      --blue: #2563EB;
      --blue-light: #EFF6FF;
      --radius: 12px;
    }
    body {
      font-family: 'Noto Sans KR', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      padding: 2.5rem 1rem;
      color: var(--text-primary);
    }
    .wrap { max-width: 580px; margin: 0 auto; }
    .header { display: flex; align-items: center; gap: 14px; margin-bottom: 2rem; animation: fadeUp 0.4s ease both; }
    .logo { width: 44px; height: 44px; border-radius: 13px; background: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 12px rgba(29,158,117,0.25); }
    .logo svg { width: 22px; height: 22px; }
    .header-text h1 { font-size: 18px; font-weight: 600; letter-spacing: -0.02em; }
    .header-text p { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 12px; animation: fadeUp 0.4s ease both; }
    .card:nth-child(2) { animation-delay: 0.05s; }
    .card:nth-child(3) { animation-delay: 0.10s; }
    .card-title { font-size: 14px; font-weight: 600; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
    .card-title .tag { font-size: 10px; font-weight: 500; padding: 2px 7px; border-radius: 20px; background: var(--accent-light); color: var(--accent); }
    .card-title .tag.blue { background: var(--blue-light); color: var(--blue); }
    .card-desc { font-size: 12px; color: var(--text-secondary); margin-bottom: 1rem; line-height: 1.6; }
    .sheet-list { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1.25rem; }
    .sheet-tag { font-size: 11px; padding: 3px 10px; border-radius: 6px; border: 1px solid var(--border); color: var(--text-secondary); background: var(--bg); }
    .drop-zone { border: 1.5px dashed var(--border); border-radius: 10px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.18s, background 0.18s; position: relative; }
    .drop-zone:hover, .drop-zone.drag-over { border-color: var(--accent); background: var(--accent-light); }
    .drop-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
    .drop-icon { font-size: 28px; margin-bottom: 8px; }
    .drop-text { font-size: 13px; font-weight: 500; color: var(--text-primary); }
    .drop-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }
    .file-selected { display: none; align-items: center; gap: 10px; padding: 10px 14px; background: var(--accent-light); border: 1px solid #A7E3CE; border-radius: 8px; margin-top: 10px; }
    .file-selected.show { display: flex; }
    .file-name { flex: 1; font-size: 12px; font-weight: 500; color: var(--accent-dark); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .file-clear { font-size: 16px; color: var(--accent); cursor: pointer; line-height: 1; background: none; border: none; padding: 0; }
    .btn { width: 100%; padding: 12px; border-radius: 8px; border: none; font-family: 'Noto Sans KR', sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; margin-top: 12px; transition: background 0.18s, transform 0.1s, opacity 0.18s; }
    .btn:active { transform: scale(0.98); }
    .btn-primary { background: var(--accent); color: white; }
    .btn-primary:hover { background: var(--accent-dark); }
    .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
    .btn-blue { background: var(--blue); color: white; }
    .btn-blue:hover { background: #1d4ed8; }
    .btn-blue:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
    .log-wrap { background: #1A1D23; border-radius: 10px; padding: 14px 16px; margin-top: 10px; max-height: 130px; overflow-y: auto; display: none; }
    .log-wrap.show { display: block; }
    .log-line { font-size: 11px; font-family: 'Consolas', monospace; line-height: 1.8; }
    .log-line.info  { color: #6EE7B7; }
    .log-line.error { color: #FCA5A5; }
    .log-line.warn  { color: #FCD34D; }
    .progress-wrap { margin-top: 10px; display: none; }
    .progress-wrap.show { display: block; }
    .progress-bar-bg { height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; }
    .progress-bar { height: 100%; background: var(--accent); border-radius: 99px; width: 0%; transition: width 0.3s ease; }
    .progress-text { font-size: 11px; color: var(--text-tertiary); margin-top: 5px; text-align: center; }
    .footer { margin-top: 1.75rem; padding-top: 1.25rem; border-top: 1px solid var(--border); font-size: 11px; color: var(--text-tertiary); text-align: center; animation: fadeUp 0.4s 0.2s ease both; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>
<div class="wrap">
  <div class="header">
    <div class="logo">
      <svg viewBox="0 0 22 22" fill="none">
        <rect x="2" y="2" width="7" height="7" rx="2" fill="white" opacity="0.9"/>
        <rect x="11" y="2" width="7" height="7" rx="2" fill="white" opacity="0.55"/>
